# Copy to .env (optional). Used by docker-compose and local tooling examples.

# Django
DJANGO_DEBUG=1
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Postgres (if POSTGRES_HOST is set, Django uses Postgres instead of SQLite)
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=platform
POSTGRES_USER=platform
POSTGRES_PASSWORD=platform

# Frontend URL (email links)
FRONTEND_URL=http://localhost:5173

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Email (Mailpit in docker-compose)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=mailpit
EMAIL_PORT=1025
EMAIL_USE_TLS=0
DEFAULT_FROM_EMAIL=noreply@example.com

# Commission rate for mock payments (0.15 = 15%)
PLATFORM_COMMISSION_RATE=0.15

# Seed users (docker-compose / local)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=adminadmin12

# Optional: OpenAI for campaign diagnostic (embeddings + LLM refinement)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_EMBEDDING_DIMENSIONS=512

# VITE_API_BASE_URL=http://127.0.0.1:8000/api/v1
